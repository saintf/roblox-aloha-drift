{
  "name": "AlohaD rift",
  "globIgnorePaths": ["**/_Index/**"],
  "tree": {
    "$className": "DataModel",
    "ServerScriptService": {
      "$className": "ServerScriptService",
      "AlohaServer": {
        "$path": "src/server"
      }
    },
    "StarterPlayer": {
      "$className": "StarterPlayer",
      "StarterPlayerScripts": {
        "$className": "StarterPlayerScripts",
        "AlohaClient": {
          "$path": "src/client"
        }
      }
    },
    "ReplicatedStorage": {
      "$className": "ReplicatedStorage",
      "AlohaShared": {
        "$path": "src/shared"
      },
      "Packages": {
        "$path": "Packages"
      }
    },
    "TestService": {
      "$className": "TestService",
      "AlohaTests": {
        "$path": "tests"
      }
    }
  }
}
